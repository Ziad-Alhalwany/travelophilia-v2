# ==========================================
# Travelophilia - Environment Variables Example
# ==========================================
# تعليمات: انسخ هذا الملف وسمّه .env وضع فيه القيم الحقيقية.
# تحذير: لا تقم برفع ملف .env الحقيقي إلى GitHub نهائياً!

# --- Django Security ---
SECRET_KEY=your_secret_key_here_do_not_share
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL Database ---
DB_NAME=travelophilia_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# --- Frontend (Vite) ---
# توضع في ملف .env في فولدر src/
VITE_API_BASE_URL=http://127.0.0.1:8000/api